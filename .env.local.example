NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: required for recording verified PayPal donations (bypasses RLS safely)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PayPal Live (set PAYPAL_MODE=live). For sandbox omit PAYPAL_MODE or set sandbox.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_SECRET=YOUR_PAYPAL_SECRET
PAYPAL_WEBHOOK_ID=YOUR_PAYPAL_WEBHOOK_ID
PAYPAL_MODE=live

# Optional explicit API host (overrides PAYPAL_MODE default if set)
# Sandbox: https://api-m.sandbox.paypal.com
# Live: https://api-m.paypal.com
# PAYPAL_API_BASE=https://api-m.paypal.com
